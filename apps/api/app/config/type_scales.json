  "typography_execution_laws": {
    "universal_rules": {
      "max_typefaces_per_asset": 2,
      "max_weights_per_typeface": 3,
      "max_sizes_in_hierarchy": 6,
      "kerning_mandate": "Display type (48px+) must be manually kerned or tight tracked",
      "line_length_optimal_chars": 65,
      "line_length_max_chars": 90,
      "widows_orphans": "forbidden_in_print_and_premium_digital"
    },

    "tracking_rules": {
      "display_48px_plus": {
        "tracking_em": -0.03,
        "description": "Tight tracking. Tighten until uncomfortable, back off 10%."
      },
      "headline_24_to_48px": {
        "tracking_em": -0.02,
        "description": "Slightly tight. Improves readability at large sizes."
      },
      "body_14_to_20px": {
        "tracking_em": 0,
        "description": "Default tracking. Let font breathe."
      },
      "ALL_CAPS": {
        "tracking_em": 0.05,
        "description": "Open tracking. CAPS need air to read well."
      },
      "small_text_12px_below": {
        "tracking_em": 0.01,
        "description": "Slightly open. Improves legibility at tiny sizes."
      }
    },

    "weight_contrast_psychology": {
      "Black_with_Light": "Maximum sophistication. Editorial luxury.",
      "Bold_with_Regular": "Standard professional. Safe readable.",
      "Black_with_Medium": "Tech modern. Clean confident.",
      "Light_with_Light": "Ultra minimal. Risky but powerful if right context."
    },

    "case_psychology": {
      "ALL_CAPS": {
        "emotion": "power_urgency_declaration_authority",
        "use_when": "headlines_cta_buttons_brand_names",
        "tracking_adjustment": "+0.05em to +0.1em required"
      },
      "Title_Case": {
        "emotion": "formal_corporate_trustworthy_traditional",
        "use_when": "headlines_professional_contexts",
        "caution": "Can feel dated if overused"
      },
      "Sentence_case": {
        "emotion": "warmth_approachability_storytelling_modern",
        "use_when": "body_copy_conversational_brands",
        "best_for": "Gen Z millennial targeting"
      },
      "lowercase_only": {
        "emotion": "casual_friendly_anti_corporate_modern",
        "use_when": "youth_brands_tech_startups",
        "caution": "Can harm legibility in small sizes"
      }
    },

    "text_on_image_treatments": {
      "overlay_dark": {
        "css": "background: rgba(0,0,0,0.5); padding: 20px;",
        "use_when": "Universal legibility needed. Safe bet.",
        "platforms": ["all"]
      },
      "color_block": {
        "css": "background: brand_color; padding: 15px 30px;",
        "use_when": "Bold editorial. Brand color showcase.",
        "platforms": ["instagram", "print"]
      },
      "text_shadow": {
        "css": "text-shadow: 0 2px 20px rgba(0,0,0,0.8);",
        "use_when": "Subtle depth. Maintains image visibility.",
        "platforms": ["social", "web"]
      },
      "blur_behind": {
        "css": "backdrop-filter: blur(20px); background: rgba(255,255,255,0.1);",
        "use_when": "Modern glass effect. Premium feel.",
        "platforms": ["web", "app_ui"]
      },
      "outlined_text": {
        "css": "-webkit-text-stroke: 2px white; color: black;",
        "use_when": "Maximum legibility on any background.",
        "platforms": ["youtube_thumbnail", "tiktok"]
      },
      "knockout_contrast": {
        "css": "White text on dark image zones OR black text on light zones",
        "use_when": "Clean. High contrast. No overlay needed.",
        "platforms": ["luxury_editorial", "minimal_brands"]
      }
    }
  },

  "scale_selection_rules": {
    "by_platform": {
      "instagram_feed": "poster_impact",
      "instagram_story": "mobile_thumb_zone",
      "youtube_thumbnail": "poster_impact",
      "linkedin": "digital_efficiency",
      "print_magazine": "editorial_refined",
      "billboard": "billboard_distance",
      "tiktok": "mobile_thumb_zone",
      "web_app": "digital_efficiency",
      "luxury_website": "editorial_refined"
    },

    "by_brand_personality": {
      "bold_disruptive": "poster_impact",
      "refined_luxury": "editorial_refined",
      "tech_efficient": "digital_efficiency",
      "mass_market_simple": "poster_impact",
      "editorial_storytelling": "editorial_refined"
    },

    "by_viewing_distance": {
      "300_feet_plus": "billboard_distance",
      "10_to_30_feet": "poster_impact",
      "arm_length_print": "editorial_refined",
      "screen_desktop": "digital_efficiency",
      "screen_mobile": "mobile_thumb_zone"
    }
  },

  "notes": [
    "Typography scale is the invisible grid — break it and design falls apart",
    "Hierarchy ratio (e.g., 8:5.33:2.67) creates visual rhythm — random sizes = visual chaos",
    "Tracking (letter-spacing) is as important as size — neglect it = amateur",
    "Platform constrains scale choice — billboard needs billboard_distance, not editorial_refined",
    "Learning Engine should track which scales convert best per platform + industry"
  ]
}
