    "billboard_distance": {
      "scale_id": "billboard_distance",
      "scale_name": "BILLBOARD DISTANCE",
      "use_case": "Out-of-home advertising, billboards, bus shelters, airport displays, stadium signage",

      "philosophy": "Readable at 300 feet. 2 seconds to understand. Maximum simplicity.",

      "scale_px": {
        "display_hero": {
          "size_px": 300,
          "size_pt_at_source": 300,
          "line_height": 0.9,
          "tracking_em": -0.04,
          "weight": 900,
          "case": "CAPS",
          "role": "The entire message. 3-7 words max.",
          "max_words": 7,
          "readable_at": "300_feet_40mph"
        },
        "tagline_secondary": {
          "size_px": 120,
          "size_pt_at_source": 120,
          "line_height": 1.0,
          "tracking_em": 0,
          "weight": 700,
          "case": "Title Case",
          "role": "Brand name or URL. Single line.",
          "max_chars": 20,
          "readable_at": "150_feet"
        },
        "legal_minimum": {
          "size_px": 60,
          "size_pt_at_source": 60,
          "line_height": 1.2,
          "tracking_em": 0.02,
          "weight": 400,
          "case": "Sentence case",
          "role": "ONLY if legally required. Avoid if possible.",
          "max_chars": 30,
          "readable_at": "50_feet"
        }
      },

      "hierarchy_ratio": "10:4:2",
      "contrast_strategy": "extreme_single_message_dominance",

      "typeface_recommendations": {
        "display_hero": ["Anton", "Bebas Neue", "Archivo Black", "Impact"],
        "tagline": ["Bebas Neue", "Oswald Bold"],
        "legal": ["Arial Bold", "Helvetica Bold"]
      },

      "platform_fit": ["billboard_outdoor", "bus_shelter", "airport_display", "stadium_signage"],

      "mandatory_rules": [
        "MAX 7 words total on entire billboard",
        "Font size minimum 300pt at source file for primary message",
        "High contrast mandatory (black on yellow, white on dark)",
        "No fine print except legal requirements",
        "No URLs unless absolutely necessary (QR code preferred)",
        "Readable in 2 seconds at 40mph test required"
      ]
    },

