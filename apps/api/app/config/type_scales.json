  "type_scales": {
    "poster_impact": {
      "scale_id": "poster_impact",
      "scale_name": "POSTER IMPACT",
      "use_case": "Event posters, social feed ads, scroll-stop visuals, bold declarations",

      "philosophy": "Maximum contrast. Impossible to ignore. Type as architecture.",

      "scale_px": {
        "display_hero": {
          "size_px": 96,
          "size_rem": 6.0,
          "line_height": 1.0,
          "tracking_em": -0.05,
          "weight": 900,
          "case": "CAPS",
          "role": "The declaration. Single word or 2-3 word power phrase.",
          "max_chars": 15
        },
        "headline_primary": {
          "size_px": 64,
          "size_rem": 4.0,
          "line_height": 1.1,
          "tracking_em": -0.03,
          "weight": 700,
          "case": "CAPS or Title Case",
          "role": "Main message. Brand name or event title.",
          "max_chars": 30
        },
        "subheadline": {
          "size_px": 32,
          "size_rem": 2.0,
          "line_height": 1.3,
          "tracking_em": 0,
          "weight": 600,
          "case": "Sentence case",
          "role": "Supporting message. Context or tagline.",
          "max_chars": 50
        },
        "body_large": {
          "size_px": 20,
          "size_rem": 1.25,
          "line_height": 1.5,
          "tracking_em": 0,
          "weight": 400,
          "case": "Sentence case",
          "role": "Body copy if needed. Event details.",
          "max_chars": 100
        },
        "cta_button": {
          "size_px": 18,
          "size_rem": 1.125,
          "line_height": 1.2,
          "tracking_em": 0.05,
          "weight": 700,
          "case": "CAPS",
          "role": "Call to action button text.",
          "max_chars": 20
        },
        "caption_small": {
          "size_px": 12,
          "size_rem": 0.75,
          "line_height": 1.4,
          "tracking_em": 0,
          "weight": 400,
          "case": "Sentence case",
          "role": "Fine print. Dates, legal, disclaimers.",
          "max_chars": 200
        }
      },

      "hierarchy_ratio": "8:5.33:2.67:1.67:1.5:1",
      "contrast_strategy": "extreme_size_jumps_maximum_visual_hierarchy",

      "typeface_recommendations": {
