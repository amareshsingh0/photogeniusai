{
  "_meta": {
    "system": "BEAST Creative Studio — Composition Archetypes Library",
    "version": "2026-Q2",
    "updated_at": "2026-04-07",
    "philosophy": "Composition is not decoration. It's the reading path. The power hierarchy. The invisible force that guides the eye.",
    "archetypes_count": 7
  },

  "archetypes": {
    "hero_dominant": {
      "archetype_id": "hero_dominant",
      "archetype_name": "HERO DOMINANT",

      "visual_description": "Subject is the entire story. Minimal background noise. 80% visual weight on hero element.",
      "energy": "still_confident_self_evident_powerful",
      "reading_path": "instant_focal_point_no_journey_needed",

      "composition_rules": {
        "visual_weight": "80_image_20_type",
        "grid": "image_bleeds_to_edges_or_generous_negative_space",
        "subject_position": "centered_or_rule_of_thirds_dominant",
        "background_treatment": "minimal_clean_blur_or_seamless",
        "focal_point": "single_unmissable_hero_element"
      },

      "space_character": {
        "type": "generous_breathing_room",
        "margin_multiplier": 1.5,
        "density": "low_20_to_30_percent_filled",
        "whitespace_role": "lets_hero_breathe_premium_signal"
      },

      "typography_treatment": {
        "text_placement": "floats_in_clear_zones_never_competes_with_hero",
        "text_size_hierarchy": "headline_medium_not_competing",
        "text_weight": "20_percent_max_visual_attention",
        "acceptable_placements": ["top_center", "bottom_third", "side_margin"]
      },

      "when_to_use": [
        "product_is_the_story",
        "beauty_product_closeup",
        "fashion_hero_garment",
        "luxury_showcase",
        "app_icon_hero",
        "portrait_editorial"
      ],

      "avoid_when": [
        "message_more_important_than_visual",
        "complex_multi_product",
        "text_heavy_poster",
        "infographic_data_visualization"
      ],

      "platform_fit": {
        "best": ["instagram_feed", "print_poster", "billboard", "product_page", "email_hero"],
        "poor": ["youtube_thumbnail_text_heavy", "banner_ads_small_space"]
      },

      "examples_reference": [
        "Apple product photography",
        "Fashion editorial single garment",
        "Luxury watch closeup",
        "Food hero shot (single dish dominating)",
        "Beauty product on clean background"
      ],

      "prompt_engineering_notes": {
        "subject_instruction": "subject_centered_full_frame_dominant_presence",
        "background_instruction": "minimal_background_detail_negative_space_clean",
        "camera_angle": "straight_on_or_hero_angle_slightly_below",
        "lighting": "clean_studio_or_editorial_natural_light",
        "depth": "shallow_depth_of_field_hero_sharp_background_soft"
      }
    },

